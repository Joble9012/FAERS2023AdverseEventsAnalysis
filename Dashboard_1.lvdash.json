            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "3f46a8a9",
                  "fields": [
                    {
                      "name": "Drug_Name_Clean",
                      "expression": "`Drug_Name_Clean`"
                    },
                    {
                      "name": "sum(death_cases)",
                      "expression": "SUM(`death_cases`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "showTitle": true,
                "title": "Top 5 Drugs with Most Deaths"
              },
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "Drug_Name_Clean",
                  "displayName": "Drug Name",
                  "scale": {
                    "type": "categorical"
                  }
                },
                "y": {
                  "fieldName": "sum(death_cases)",
                  "displayName": "Death Count",
                  "scale": {
                    "type": "quantitative"
                  }
                }
              }
            }
          },
          "position": {
            "x": 4,
            "y": 6,
            "width": 8,
            "height": 6
          }
        },
        {
          "widget": {
            "name": "top-reaction-type-drug-use",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "cea002cd",
                  "fields": [
                    {
                      "name": "Preferred_Term_For_Event",
                      "expression": "`Preferred_Term_For_Event`"
                    },
                    {
                      "name": "reaction_count",
                      "expression": "`reaction_count`"
                    }
                  ],
                  "filters": [
                    {
                      "expression": "`Preferred_Term_For_Event` ILIKE `Preferred_Term_For_Event` OR TRUE"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "showDescription": false,
                "showTitle": true,
                "title": "Top Drug Reaction Type Reported",
                "headerAlignment": "center"
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "reaction_count"
                },
                "target": {
                  "fieldName": "Preferred_Term_For_Event"
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 4,
            "height": 6
          }
